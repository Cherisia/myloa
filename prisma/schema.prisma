generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  name            String?
  /// Discord 로그인명 (@username)
  discordUsername String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  nickname        String? // 공격대에서 남들에게 보이는 닉네임
  raidPublic        Boolean   @default(true) // 공격대원에게 레이드 현황 공개 여부
  raidPublicFriends Boolean   @default(true) // 친구에게 레이드 현황 공개 여부
  repCharId       String? // 대표 캐릭터 ID
  apiKey          String? // 로스트아크 API 키 (AES-256 암호화) — 계정당 하나
  lastSyncedAt    DateTime? // 마지막 LoA API 동기화 시각
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  loaExpeditions      LoaExpedition[]
  expeditionMember    ExpeditionMember[]
  leadingExpeditions  Expedition[]                @relation("ExpeditionLeader")
  expeditionFavorites ExpeditionMemberFavorite[]  @relation("FavoriteViewer")
  sentFriendRequests     FriendRequest[]  @relation("FriendRequestSender")
  receivedFriendRequests FriendRequest[]  @relation("FriendRequestReceiver")
  favoritedFriends       UserFavorite[]   @relation("FavoriteOwner")
  favoritedBy            UserFavorite[]   @relation("FavoriteTarget")
  weeklyRaidHistories    WeeklyRaidHistory[]
  feedbacks              Feedback[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── 원정대 ───────────────────────────────────────────────────────────────────
// 로스트아크 계정의 서버 단위 캐릭터 집합 (디스코드 계정당 여러 원정대 가능)

model LoaExpedition {
  id          String   @id @default(cuid())
  userId      String
  repCharName String? // 대표 캐릭터명 (변경 가능)
  customName  String? // 사용자 지정 탭 이름
  createdAt   DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  characters Character[]

  @@index([userId])
}

// ─── 캐릭터 ──────────────────────────────────────────────────────────────────

model Character {
  id           String   @id @default(cuid())
  expeditionId String // FK → LoaExpedition
  name         String
  class        String
  server       String
  itemLevel    Float
  combatPower  Float?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  expedition     LoaExpedition      @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  characterRaids CharacterRaid[]
  customItems    CharacterCustomItem[]

  @@index([expeditionId])
}

// ─── 숙제 ─────────────────────────────────────────────────────────────────────

model CharacterRaid {
  id          String    @id @default(cuid())
  characterId String
  raidId      String // lib/raidData.js 의 raid id
  difficulty  String // "normal" | "hard" | "nightmare" 등
  gateClears  Boolean[] // 관문별 클리어 여부 배열
  isGoldCheck Boolean   @default(true)
  moreDone    Boolean   @default(false)
  moreFrom    String    @default("bound") // "bound" | "trade"
  resetAt     DateTime // 다음 수요일 06:00 KST
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, raidId, difficulty])
  @@index([resetAt])
  @@index([characterId, resetAt])
}

// ─── 커스텀 숙제 ──────────────────────────────────────────────────────────────

model CharacterCustomItem {
  id          String    @id @default(cuid())
  characterId String
  name        String
  type        String    // 'daily' | 'weekly'
  image       String?
  sortOrder   Int       @default(0)
  done        Boolean   @default(false)
  lastDoneAt  DateTime?
  restGauge   Int       @default(0)
  deducted    Boolean   @default(false)
  resetAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, name])
  @@index([type, resetAt])
}

// ─── 공격대 (공격대 기능용, LoA 원정대와 별개) ──────────────────────────────────

model Expedition {
  id          String   @id @default(cuid())
  name        String
  description String?  // 그룹 소개
  notice      String?  // 공지사항
  leaderId    String
  inviteCode  String   @unique @default(cuid())
  maxMembers  Int      @default(100)
  autoAccept  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leader    User                      @relation("ExpeditionLeader", fields: [leaderId], references: [id])
  members   ExpeditionMember[]
  favorites ExpeditionMemberFavorite[]
}

model ExpeditionMember {
  id           String    @id @default(cuid())
  expeditionId String
  userId       String
  role         String    @default("member") // "member" — 길드장은 Expedition.leaderId로 판별 (별도 역할 없음)
  status       String    @default("pending") // "pending" | "active" | "rejected" | "left"
  visibility   String    @default("all")    // "all" | "none"
  joinedAt     DateTime?
  createdAt    DateTime  @default(now())

  expedition Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expeditionId, userId])
  @@index([userId])
  @@index([expeditionId, status])
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("pending") // "pending" | "accepted" | "rejected"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
}

model UserFavorite {
  id           String   @id @default(cuid())
  userId       String
  targetUserId String
  createdAt    DateTime @default(now())

  user   User @relation("FavoriteOwner", fields: [userId], references: [id], onDelete: Cascade)
  target User @relation("FavoriteTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([userId, targetUserId])
}

// ─── 주간 숙제 기록 ────────────────────────────────────────────────────────────
// 매주 수요일 리셋 시점의 레이드 완료 현황 스냅샷

model WeeklyRaidHistory {
  id         String   @id @default(cuid())
  userId     String
  weekStart  DateTime // 해당 주 스냅샷 시각 (수요일 06:00 KST)
  totalRaids          Int      // 완료한 전체 레이드 수
  goldRaids           Int      // 완료한 골드 레이드 수
  configuredTotalRaids Int     @default(0) // 설정된 전체 레이드 수 (완료 여부 무관)
  configuredGoldRaids Int      @default(0) // 설정된 골드 레이드 수 (완료 여부 무관)
  totalGold           Int      // 골드 레이드 합산 골드 (귀속+거래)
  goldMore            Int      @default(0) // 더보기 추가 골드 합계
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
}

model ExpeditionMemberFavorite {
  id           String @id @default(cuid())
  expeditionId String
  viewerUserId String
  targetUserId String

  expedition Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  viewer     User       @relation("FavoriteViewer", fields: [viewerUserId], references: [id], onDelete: Cascade)

  @@unique([expeditionId, viewerUserId, targetUserId])
}

// ─── 길드 일정 ────────────────────────────────────────────────────────────────

model GuildSchedulePost {
  id              String    @id @default(cuid())
  expeditionId    String
  creatorId       String
  raidId          String
  difficulty      String
  scheduledAt     DateTime
  durationMinutes Int       @default(120)
  totalSlots      Int
  minItemLevel    Float?
  allowedClasses  String[]
  memo            String?   @db.VarChar(140)
  closedAt        DateTime
  /// recruiting | closed | done | disbanded
  status          String    @default("recruiting")
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  participants GuildScheduleParticipant[]
  partySlots   GuildSchedulePartySlot[]

  @@index([expeditionId])
  @@index([scheduledAt])
}

model GuildScheduleParticipant {
  id               String   @id @default(cuid())
  postId           String
  userId           String
  characterId      String
  /// support | dealer
  role             String   @default("dealer")
  /// pending | accepted | rejected
  status           String   @default("pending")
  excludedFromDone Boolean  @default(false)
  appliedAt        DateTime @default(now())

  post GuildSchedulePost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model GuildSchedulePartySlot {
  id          String  @id @default(cuid())
  postId      String
  partyNumber Int
  slotNumber  Int
  userId      String?
  characterId String?
  customName  String?
  customClass String?

  post GuildSchedulePost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, partyNumber, slotNumber])
  @@index([postId])
}

model MemberAvailability {
  id           String   @id @default(cuid())
  userId       String
  expeditionId String
  /// JSON: ["MON:2100","MON:2115",...] — 내부 해상도 15분 고정
  slots        String   @default("[]")
  /// 표시 단위: 15 | 30 | 60
  displayUnit  Int      @default(30)
  updatedAt    DateTime @updatedAt

  @@unique([userId, expeditionId])
  @@index([expeditionId])
}

// ─── 문의/피드백 ──────────────────────────────────────────────────────────────

model Feedback {
  id       String  @id @default(cuid())
  userId   String?
  category String  // 'bug' | 'suggestion' | 'other'
  content  String  @db.Text
  contact  String? // 선택적 연락처 (이메일 or Discord ID)
  status   String  @default("new") // 'new' | 'read' | 'resolved'
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}
