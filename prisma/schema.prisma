generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  name            String?
  /// Discord 로그인명 (@username)
  discordUsername String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  repCharId       String? // 대표 캐릭터 ID
  apiKey          String? // 로스트아크 API 키 (AES-256 암호화) — 계정당 하나
  lastSyncedAt    DateTime? // 마지막 LoA API 동기화 시각
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  loaExpeditions      LoaExpedition[]
  expeditionMember    ExpeditionMember[]
  leadingExpeditions  Expedition[]                @relation("ExpeditionLeader")
  expeditionFavorites ExpeditionMemberFavorite[]  @relation("FavoriteViewer")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── 원정대 ───────────────────────────────────────────────────────────────────
// 로스트아크 계정의 서버 단위 캐릭터 집합 (디스코드 계정당 여러 원정대 가능)

model LoaExpedition {
  id          String   @id @default(cuid())
  userId      String
  repCharName String? // 대표 캐릭터명 (변경 가능)
  customName  String? // 사용자 지정 탭 이름
  createdAt   DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  characters Character[]
}

// ─── 캐릭터 ──────────────────────────────────────────────────────────────────

model Character {
  id           String   @id @default(cuid())
  expeditionId String // FK → LoaExpedition
  name         String
  class        String
  server       String
  itemLevel    Float
  combatPower  Float?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  expedition     LoaExpedition      @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  characterRaids CharacterRaid[]
  customItems    CharacterCustomItem[]
}

// ─── 숙제 ─────────────────────────────────────────────────────────────────────

model CharacterRaid {
  id          String    @id @default(cuid())
  characterId String
  raidId      String // lib/raidData.js 의 raid id
  difficulty  String // "normal" | "hard" | "nightmare" 등
  gateClears  Boolean[] // 관문별 클리어 여부 배열
  isGoldCheck Boolean   @default(true)
  moreDone    Boolean   @default(false)
  moreFrom    String    @default("bound") // "bound" | "trade"
  resetAt     DateTime // 다음 수요일 06:00 KST
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, raidId, difficulty])
}

// ─── 커스텀 숙제 ──────────────────────────────────────────────────────────────

model CharacterCustomItem {
  id          String    @id @default(cuid())
  characterId String
  name        String
  type        String    // 'daily' | 'weekly'
  image       String?
  sortOrder   Int       @default(0)
  done        Boolean   @default(false)
  restGauge   Int       @default(0)
  deducted    Boolean   @default(false)
  resetAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, name])
}

// ─── 그룹 (그룹 기능용, LoA 원정대와 별개) ──────────────────────────────────

model Expedition {
  id          String   @id @default(cuid())
  name        String
  description String?  // 그룹 소개
  notice      String?  // 공지사항
  leaderId    String
  inviteCode  String   @unique @default(cuid())
  maxMembers  Int      @default(8)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leader    User                      @relation("ExpeditionLeader", fields: [leaderId], references: [id])
  members   ExpeditionMember[]
  favorites ExpeditionMemberFavorite[]
}

model ExpeditionMember {
  id           String    @id @default(cuid())
  expeditionId String
  userId       String
  role         String    @default("member") // "officer" | "member"
  status       String    @default("pending") // "pending" | "active" | "rejected" | "left"
  visibility   String    @default("all")    // "all" | "none"
  joinedAt     DateTime?
  createdAt    DateTime  @default(now())

  expedition Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expeditionId, userId])
}

model ExpeditionMemberFavorite {
  id           String @id @default(cuid())
  expeditionId String
  viewerUserId String
  targetUserId String

  expedition Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  viewer     User       @relation("FavoriteViewer", fields: [viewerUserId], references: [id], onDelete: Cascade)

  @@unique([expeditionId, viewerUserId, targetUserId])
}
