!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── 환경변수 / 시크릿 ────────────────────────────────────────────────────────
# 모든 .env 파일 제외 (.env.example / .env.sample 은 커밋 가능)
.env
.env.*
!.env.example
!.env.sample
!.env.template

# 개인 키 / 인증서
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
secrets/
