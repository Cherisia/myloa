# ── Next.js ──────────────────────────────────────────────────────────────────
.next/
out/
next-env.d.ts

# ── 빌드 결과물 ───────────────────────────────────────────────────────────────
build/
dist/
coverage/

# ── Prisma 생성 파일 ──────────────────────────────────────────────────────────
# (prisma/migrations 는 버전 관리 대상 — 제외하지 않음)
lib/generated/
*.db
*.db-journal
*.sqlite

# ── 로그 ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

